{
  "name": "mcdev-mcp",
  "version": "1.0.0",
  "description": "MCP server for Minecraft mod development - provides decompiled code access, symbol search, and runtime interaction via DebugBridge",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcdev-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js serve",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "mcpb": "bash scripts/build-mcpb.sh"
  },
  "keywords": [
    "minecraft",
    "mcp",
    "fabric",
    "modding",
    "decompiler",
    "model-context-protocol",
    "ai",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weikengchen/mcdev-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/weikengchen/mcdev-mcp/issues"
  },
  "homepage": "https://github.com/weikengchen/mcdev-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.6.0",
    "commander": "^12.0.0",
    "env-paths": "^4.0.0",
    "glob": "^10.0.0",
    "unzipper": "^0.12.3",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/unzipper": "^0.10.10",
    "@types/ws": "^8.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
