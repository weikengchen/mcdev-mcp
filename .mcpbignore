# mcpb pack already excludes: .git, .gitignore, *.d.ts, *.map, *.mcpb,
# tsconfig.json, package-lock.json, node_modules/.cache, node_modules/.bin,
# .DS_Store, etc. (see EXCLUDE_PATTERNS in @anthropic-ai/mcpb).
#
# This file adds project-specific exclusions on top of those defaults.
# It's also copied into the staging dir by scripts/build-mcpb.sh so it
# applies to the staged production node_modules tree.

# Source, tests, docs, dev tooling — dist/ is what actually ships.
src/
tests/
jest.config.js
docs/
.github/
.ruff_cache/

# Build output of the mcpb script itself.
dist-mcpb/

# Trim docs, changelogs, and TypeScript sources out of bundled dependencies.
# These ship in many npm packages and add MBs without runtime value.
node_modules/**/*.md
node_modules/**/CHANGELOG*
node_modules/**/HISTORY*
node_modules/**/LICENSE
node_modules/**/*.ts
